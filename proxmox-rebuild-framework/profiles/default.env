# Proxmox rebuild framework – default profile
# Optional: set flags for future snapshot/restore behaviour.
# Example:
# RESTORE_ETC_PVE_TAR=0
#
# Full /etc archive (disabled by default; can contain secrets)
# SNAPSHOT_ETC_ALL=1
# RESTORE_ETC_ALL=1

# Optional: restore APT packages from snapshot (filtered manual list)
# RESTORE_APT_PACKAGES=true
